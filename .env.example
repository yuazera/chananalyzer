# ChanAnalyzer 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值

# ==================== 必需配置 ====================

# Tushare API Token
# 获取地址: https://tushare.pro/register
# 用途: A股行情数据获取
TUSHARE_TOKEN=your_tushare_token_here

# DeepSeek API Key
# 获取地址: https://platform.deepseek.com/api_keys
# 用途: AI 智能分析功能
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==================== 可选配置 ====================

# 数据库连接字符串 (默认: sqlite:///./chan.db)
# DATABASE_URL=sqlite:///./chan.db

# JWT 密钥 (默认: chanalyzer-secret-key-change-in-production)
# 生产环境建议修改为随机字符串
# JWT_SECRET_KEY=your-random-secret-key

# 最大并发扫描数 (默认: 5)
# MAX_CONCURRENT_SCANS=5

# 服务端口 (默认: 8000)
# PORT=8000

# ==================== 云平台配置 (自动检测) ====================
# RENDER=true
# RAILWAY=true
